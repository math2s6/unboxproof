PORT=3000
JWT_SECRET=change_me_in_production
ADMIN_SECRET=change_me_super_secret_admin_key
JWT_REFRESH_SECRET=change_me_too
VERIFICATION_CODE_SECRET=unique_hmac_secret
PLATFORM_FEE_PERCENT=5
NODE_ENV=production

# URL publique de l'app (pour les liens dans les emails)
APP_URL=https://ton-app.onrender.com

# SMTP réel (ex: Brevo)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=ton@email.com
SMTP_PASS=ta-cle-api-brevo
SMTP_FROM="UnboxProof" <noreply@unboxproof.io>

# Base de données Turso (SQLite hébergé - persistant)
TURSO_URL=libsql://your-db-name.turso.io
TURSO_TOKEN=your-auth-token
